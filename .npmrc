# Some lines match current pnpm 9 defaults but are kept explicit so behavior
# is self-documenting and survives a default-value change in a future major.

# Install missing peer dependencies automatically.
auto-install-peers=true

# Treat unmet peer dependencies as warnings, not errors. The shadcn / radix-ui
# graph carries a few peer ranges we don't want install to fail on.
strict-peer-dependencies=false

# Symlink workspace packages into node_modules instead of resolving from the
# registry. Default in pnpm 9, flipped to false in pnpm 10 — pin it explicitly.
link-workspace-packages=true

# When adding a dep that's also available in the workspace, prefer the
# workspace copy over the registry version.
prefer-workspace-packages=true

# Save workspace deps as `workspace:^x.y.z` instead of a pinned registry
# version, so workspace updates propagate to consumers automatically.
save-workspace-protocol=rolling

# Enforce the `engines` field in package.json (Node + pnpm). Without this,
# version mismatches only emit warnings.
engine-strict=true

# Auto-install the pnpm version declared in `packageManager`, so every
# contributor and CI run uses the same pnpm. Corepack-equivalent.
manage-package-manager-versions=true